    "test unit")
      echo "  ${ACCENT}${BOLD}рџ”¬ Go unit tests${NC}"
      echo ""
      exec bash scripts/test.sh unit
      ;;
    "test dashboard")
      echo "  ${ACCENT}${BOLD}рџ”¬ Dashboard tests${NC}"
      echo ""
